# Database
DATABASE_URL="postgresql://tasktracker:tasktracker_pass@localhost:5432/tasktracker_db?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_ACCESS_SECRET="change-me-in-production"
